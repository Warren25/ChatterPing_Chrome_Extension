# ============================================
# ChatterPing Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env
# ============================================

# Server Configuration
# --------------------
# Port for the Express server to listen on
PORT=3001

# OpenAI Configuration (REQUIRED)
# -------------------------------
# Get your API key from: https://platform.openai.com/api-keys
# Used for generating AI summaries of mentions (GPT-4o-mini)
OPENAI_API_KEY=sk-your-api-key-here

# API Authentication (REQUIRED in production)
# --------------------------------------------
# Shared secret between the Chrome extension and server.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Must also be set in extension/config/config.js
CHATTERPING_API_KEY=

# Reddit API Configuration (OPTIONAL)
# ------------------------------------
# Currently using public JSON API, no auth required
# For higher rate limits, register an app at: https://www.reddit.com/prefs/apps
# Select "script" type for personal use
REDDIT_CLIENT_ID=
REDDIT_SECRET=
REDDIT_USER_AGENT=ChatterPing/0.1